# ============================================================
# CONFIGURATION BACKEND - VARIABLES D'ENVIRONNEMENT
# ============================================================
# Copier ce fichier en .env et remplir les valeurs
# IMPORTANT: Ne jamais commiter le fichier .env en production!

# ============================================================
# BASE DE DONNÉES POSTGRESQL
# ============================================================
# Option 1: Utiliser DATABASE_URL (pour Render, Heroku, etc.)
DATABASE_URL=postgresql://user:password@localhost:5432/sinoa_kpop

# Option 2: Ou utiliser les variables individuelles
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sinoa_kpop
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# ============================================================
# SERVEUR
# ============================================================
NODE_ENV=production
PORT=5000

# ============================================================
# AUTHENTIFICATION & SÉCURITÉ
# ============================================================
# IMPORTANT: Générer une clé JWT sécurisée en production!
# Commande: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_me_in_production_minimum_32_characters
JWT_EXPIRY=7d

# ============================================================
# FRONTEND
# ============================================================
# URL du frontend pour CORS
FRONTEND_URL=https://kpopshop.netlify.app

# ============================================================
# CREDENTIALS PAR DÉFAUT (pour initialisation seulement)
# ============================================================
# À CHANGER IMMÉDIATEMENT APRÈS LE DÉPLOIEMENT!
ADMIN_EMAIL=admin@sinoa.com
ADMIN_PASSWORD=ChangeMe123!Secure

# ============================================================
# OPTIONNEL: EMAIL (configuration future)
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password

# ============================================================
# OPTIONNEL: STOCKAGE D'IMAGES (S3/AWS)
# ============================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=sinoa-kpop
AWS_REGION=eu-west-1

# ============================================================
# LOGGING & DEBUG
# ============================================================
LOG_LEVEL=info
DEBUG=false
