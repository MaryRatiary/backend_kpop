# ════════════════════════════════════════════════════════════
# 🔒 CONFIGURATION DE SÉCURITÉ
# ════════════════════════════════════════════════════════════

# Environnement
NODE_ENV=production

# Port
PORT=5000

# ════════════════════════════════════════════════════════════
# 🔐 AUTHENTIFICATION & JWT
# ════════════════════════════════════════════════════════════

# IMPORTANT: Générer une clé secrète très forte (minimum 32 caractères)
# Exemple: openssl rand -base64 32
JWT_SECRET=your-very-secure-random-secret-key-minimum-32-chars

# Durée de vie du JWT (ex: 15m, 7d)
JWT_EXPIRY=15m

# Clé de chiffrement pour les données sensibles (dérivée de JWT_SECRET)
ENCRYPTION_KEY=your-encryption-key

# ════════════════════════════════════════════════════════════
# 🗄️ BASE DE DONNÉES
# ════════════════════════════════════════════════════════════

# Production (Render)
DATABASE_URL=postgresql://user:password@host:5432/database

# OU Développement (variables individuelles)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your-password
DB_NAME=sinoa_kpop

# ════════════════════════════════════════════════════════════
# 🌐 FRONTEND & CORS
# ════════════════════════════════════════════════════════════

FRONTEND_URL=https://yourdomain.com
NETLIFY_URL=https://yourdomain.netlify.app

# ════════════════════════════════════════════════════════════
# 🛍️ SHOPIFY INTEGRATION
# ════════════════════════════════════════════════════════════

SHOPIFY_SHOP_URL=https://yourshop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your-shopify-access-token
SHOPIFY_WEBHOOK_SECRET=your-webhook-secret-from-shopify

# ════════════════════════════════════════════════════════════
# 📧 EMAIL (OPTIONNEL)
# ════════════════════════════════════════════════════════════

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ════════════════════════════════════════════════════════════
# 🔔 WEBHOOKS & NOTIFICATIONS
# ════════════════════════════════════════════════════════════

WEBHOOK_SECRET=your-webhook-signing-secret

# ════════════════════════════════════════════════════════════
# 📊 LOGGING & MONITORING
# ════════════════════════════════════════════════════════════

LOG_LEVEL=info
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
